---
import { event } from "../config/event.js";
---

<section id="story" class="px-6 py-16 sm:py-20" aria-labelledby="story-title">
  <div class="mx-auto max-w-sm text-center" data-anim data-story>

    <!-- Decorative divider -->
    <div class="mb-8 flex items-center justify-center gap-4" aria-hidden="true">
      <div class="h-px flex-1 bg-chrome-200"></div>
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-chrome-400">
        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78Z"/>
      </svg>
      <div class="h-px flex-1 bg-chrome-200"></div>
    </div>

    <p class="font-sans text-[9px] font-bold uppercase tracking-[0.45em] text-chrome-500">
      Nuestra Historia
    </p>
    <h2
      id="story-title"
      class="font-vibes mt-1 text-5xl leading-tight text-chrome-800 sm:text-6xl"
    >
      50 Años Juntos
    </h2>
    <p class="mx-auto mt-6 max-w-[30ch] font-script text-base italic leading-relaxed text-chrome-700/80 text-balance">
      {event.couple.story}
    </p>

    <!-- Gold ornament -->
    <div class="mt-8 flex items-center justify-center gap-2" aria-hidden="true">
      <div class="h-px w-6 bg-chrome-300"></div>
      <div class="h-1.5 w-1.5 rounded-full bg-chrome-400"></div>
      <div class="h-px w-12 bg-chrome-300"></div>
      <div class="h-1.5 w-1.5 rounded-full bg-chrome-400"></div>
      <div class="h-px w-6 bg-chrome-300"></div>
    </div>
  </div>
</section>

<script>
  import { gsap, prefersReducedMotion, EASE } from "../lib/gsap.client.js";

  const block = document.querySelector<HTMLElement>("[data-story]");
  if (block) {
    if (prefersReducedMotion) {
      gsap.set(block, { opacity: 1 });
    } else {
      gsap.fromTo(
        block,
        { opacity: 0, y: 28 },
        {
          opacity: 1,
          y: 0,
          duration: 0.85,
          ease: EASE.expoOut,
          scrollTrigger: { trigger: block, start: "top 85%", once: true },
        }
      );
    }
  }
</script>
