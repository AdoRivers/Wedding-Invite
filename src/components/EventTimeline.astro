---
import { event } from "../config/event.js";
import "../styles/eventTimeline.css";
/**
 * Timeline de actividades del evento.
 * Cada item tiene: time, title, description y un tipo opcional (social | music | food | etc.)
 * para el ícono. Consumir desde event.js — si aún no tienes la clave `timeline`,
 * se usa el array por defecto definido aquí.
 */

interface TimelineItem {
  time: string;
  title: string;
  description: string;
  type?: "open" | "music" | "food" | "cake" | "dance" | "photo";
}

const defaultTimeline: TimelineItem[] = [
  {
    time: event.timeLabel,
    title: "Llegada & Bienvenida",
    description: "Puertas abiertas, bienvenida con drinks y la mejor vibra.",
    type: "open",
  },
  {
    time: "08:45 PM",
    title: "Cena",
    description: "Mesa lista con los platillos favoritos de la festejada.",
    type: "food",
  },
  {
    time: "09:30 PM",
    title: "Palabras & Brindis",
    description: "El momento de decir todo lo que queremos a la cumpleañera.",
    type: "cake",
  },
  {
    time: "10:00 PM",
    title: "Pastel & Sorpresa",
    description: "El esperado momento — velas, deseos y el pastel favorito.",
    type: "cake",
  },
  {
    time: "10:30 PM",
    title: "¡A bailar!",
    description: "La pista se abre: música en vivo y los mejores temas.",
    type: "dance",
  },
  {
    time: "12:00 AM",
    title: "Cierre & Fotos",
    description: "Última ronda de fotos antes de que la noche termine.",
    type: "photo",
  },
];

// Si en el futuro agregas event.timeline, lo usa; si no, el default.
const items: TimelineItem[] = (event as any).timeline ?? defaultTimeline;

const icons: Record<NonNullable<TimelineItem["type"]>, string> = {
  open:  `<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>`,
  music: `<circle cx="9" cy="18" r="3"/><circle cx="15" cy="14" r="3"/><polyline points="12 18 12 9 18 9"/>`,
  food:  `<path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>`,
  cake:  `<path d="M20 21v-8a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v8"/><path d="M4 16s.5-1 2-1 2.5 2 4 2 2.5-2 4-2 2.5 2 4 2 2-1 2-1"/><path d="M2 21h20"/><path d="M7 8v3"/><path d="M12 8v3"/><path d="M17 8v3"/><path d="M7 4h.01"/><path d="M12 4h.01"/><path d="M17 4h.01"/>`,
  dance: `<circle cx="12" cy="5" r="1"/><path d="m9 20 3-6 3 6"/><path d="m6 8 6 2 6-2"/><path d="M12 10v4"/>`,
  photo: `<path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/>`,
};
---

<section
  id="timeline"
  class="relative overflow-hidden px-5 py-16 sm:px-8 sm:py-20"
  aria-labelledby="timeline-title"
  data-timeline-section
>
  <!-- Fondo decorativo sutil -->
  <div class="absolute inset-0 timeline-bg" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-md">
    <!-- Header -->
    <div class="mb-10 sm:mb-12" data-tl-header>
      <p class="mb-1 font-sans text-[9.5px] font-semibold uppercase tracking-[0.4em] text-chrome-400">
        El programa
      </p>
      <h2 id="timeline-title" class="font-sans text-2xl font-black uppercase tracking-tight text-chrome-900 sm:text-3xl">
        Lo que viene
      </h2>
      <div class="mt-3 h-[2px] w-10 bg-chrome-900" aria-hidden="true"></div>
    </div>

    <!-- Timeline items -->
    <ol class="relative" aria-label="Programa del evento">
      <!-- Línea vertical -->
      <div class="timeline-line" aria-hidden="true">
        <div class="timeline-line-fill" data-tl-line></div>
      </div>

      {items.map((item, i) => (
        <li
          class="timeline-item group relative pb-9 pl-12 last:pb-0"
          data-tl-item
          data-index={i}
        >
          <!-- Nodo en la línea -->
          <div
            class="timeline-node"
            aria-hidden="true"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="13" height="13"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-chrome-50"
              set:html={icons[item.type ?? "open"]}
            />
          </div>

          <!-- Hora -->
          <time
            class="mb-1 block font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-chrome-400"
          >
            {item.time}
          </time>

          <!-- Título -->
          <h3 class="mb-1 font-sans text-sm font-bold uppercase tracking-wide text-chrome-900 sm:text-base">
            {item.title}
          </h3>

          <!-- Descripción -->
          <p class="font-sans text-xs leading-relaxed text-chrome-500 sm:text-sm">
            {item.description}
          </p>
        </li>
      ))}
    </ol>
  </div>
</section>

<script>
  import { gsap, ScrollTrigger, prefersReducedMotion, EASE } from "../lib/gsap.client.js";

  const section = document.querySelector<HTMLElement>("[data-timeline-section]");
  if (section) {
    const header  = section.querySelector<HTMLElement>("[data-tl-header]");
    const lineFill = section.querySelector<HTMLElement>("[data-tl-line]");
    const items   = section.querySelectorAll<HTMLElement>("[data-tl-item]");

    if (prefersReducedMotion) {
      gsap.set([header, items], { opacity: 1, y: 0, x: 0 });
      if (lineFill) gsap.set(lineFill, { scaleY: 1 });
    } else {
      // Header fade-in
      gsap.fromTo(
        header,
        { opacity: 0, y: 28 },
        {
          opacity: 1, y: 0, duration: 0.85, ease: EASE.expoOut,
          scrollTrigger: { trigger: section, start: "top 82%", once: true },
        }
      );

      // Línea vertical crece con el scroll
      if (lineFill) {
        gsap.to(lineFill, {
          scaleY: 1,
          ease: "none",
          scrollTrigger: {
            trigger: section,
            start: "top 70%",
            end: "bottom 60%",
            scrub: 1,
          },
        });
      }

      // Cada item entra desde la izquierda en stagger
      gsap.fromTo(
        items,
        { opacity: 0, x: -24 },
        {
          opacity: 1,
          x: 0,
          duration: 0.7,
          ease: EASE.expoOut,
          stagger: 0.12,
          scrollTrigger: {
            trigger: section,
            start: "top 75%",
            once: true,
          },
        }
      );
    }
  }
</script>