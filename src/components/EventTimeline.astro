---
import { event } from "../config/event.js";
import "../styles/eventTimeline.css";
/**
 * Timeline de actividades del evento.
 * Cada item tiene: time, title, description y un tipo opcional (social | music | food | etc.)
 * para el ícono y la animación GSAP asociada.
 *
 * Tipos de ícono: `snacks` (botana), `farewell` (despedida / cierre). Los nombres
 * `cake` y `dance` siguen admitidos por compatibilidad y usan los mismos trazos.
 */

interface TimelineItem {
  time: string;
  title: string;
  description: string;
  type?: "church" | "open" | "music" | "food" | "snacks" | "farewell";
}

const items = (event.timeline ?? []) as TimelineItem[];

const icons: Record<NonNullable<TimelineItem["type"]>, string> = {
  church: `<path d="m18 7 4 2v11a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V9l4-2"/><path d="M14 22v-4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v4"/><path d="M18 22V5l-6-3-6 3v17"/><path d="M12 7v5"/><path d="M10 9h4"/>`,
  open:  `<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>`,
  music: `<circle cx="9" cy="18" r="3"/><circle cx="15" cy="14" r="3"/><polyline points="12 18 12 9 18 9"/>`,
  food:  `<path d="M18 8h1a4 4 0 0 1 0 8h-1"/><path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>`,
  snacks: `<path d="M18 8a2 2 0 0 0 0-4 2 2 0 0 0-4 0 2 2 0 0 0-4 0 2 2 0 0 0-4 0 2 2 0 0 0 0 4"/><path d="M10 22 9 8"/><path d="m14 22 1-14"/><path d="M20 8c.5 0 .9.4.8 1l-2.6 12c-.1.5-.7 1-1.2 1H7c-.6 0-1.1-.4-1.2-1L3.2 9c-.1-.6.3-1 .8-1Z"/>`,
  farewell: `<path d="M5.8 11.3 2 22l10.7-3.79"/><path d="M4 3h.01"/><path d="M22 8h.01"/><path d="M15 2h.01"/><path d="M22 20h.01"/><path d="m22 2-2.24.75a2.9 2.9 0 0 0-1.96 3.12c.1.86-.57 1.63-1.45 1.63h-.38c-.86 0-1.6.6-1.76 1.44L14 10"/><path d="m22 13-.82-.33c-.86-.34-1.82.2-1.98 1.11c-.11.7-.72 1.22-1.43 1.22H17"/><path d="m11 2 .33.82c.34.86-.2 1.82-1.11 1.98C9.52 4.9 9 5.52 9 6.23V7"/><path d="M11 13c1.93 1.93 2.83 4.17 2 5-.83.83-3.07-.07-5-2-1.93-1.93-2.83-4.17-2-5 .83-.83 3.07.07 5 2Z"/>`,

};
---

<section
  id="timeline"
  class="relative overflow-hidden px-5 py-16 sm:px-8 sm:py-20"
  aria-labelledby="timeline-title"
  data-timeline-section
>
  <!-- Fondo decorativo sutil -->
  <div class="absolute inset-0 timeline-bg" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-md">
    <!-- Header -->
    <div class="mb-10 sm:mb-12" data-tl-header>
      <p class="mb-1 font-sans text-[9px] font-bold uppercase tracking-[0.45em] text-chrome-500">
        Programa
      </p>
      <h2 id="timeline-title" class="font-sans text-2xl font-black uppercase tracking-tight text-chrome-900 sm:text-3xl">
        Ceremonia &amp; Recepción
      </h2>
      <div class="mt-3 h-[2px] w-10 bg-chrome-900" aria-hidden="true"></div>
    </div>

    <!-- Timeline items -->
    <ol class="relative" aria-label="Programa del evento">
      <!-- Línea vertical -->
      <div class="timeline-line" aria-hidden="true">
        <div class="timeline-line-fill" data-tl-line></div>
      </div>

      {items.map((item, i) => (
        <li
          class="timeline-item group relative pb-9 pl-12 last:pb-0"
          data-tl-item
          data-tl-type={item.type ?? "open"}
          data-index={i}
        >
          <!-- Nodo en la línea -->
          <div
            class="timeline-node"
            aria-hidden="true"
            data-tl-node
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="13" height="13"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-chrome-50"
              data-tl-icon
              set:html={icons[item.type ?? "open"]}
            />
          </div>

          <!-- Hora -->
          <time
            class="mb-1 block font-sans text-[10px] font-semibold uppercase tracking-[0.22em] text-chrome-400"
            data-tl-time
          >
            {item.time}
          </time>

          <!-- Título -->
          <h3
            class="mb-1 font-sans text-sm font-bold uppercase tracking-wide text-chrome-900 sm:text-base"
            data-tl-title
          >
            {item.title}
          </h3>

          <!-- Descripción -->
          <p class="timeline-desc" data-tl-desc>
            {item.description}
          </p>
        </li>
      ))}
    </ol>
  </div>
</section>

<script>
  import { gsap, ScrollTrigger, prefersReducedMotion, EASE } from "../lib/gsap.client.js";

  type TimelineType = "church" | "open" | "music" | "food" | "snacks" | "farewell";

  const ITEM_FROM: Record<TimelineType, gsap.TweenVars> = {
    church:   { opacity: 0, y: -20, scale: 0.97 },
    open:     { opacity: 0, x: -28, scale: 0.92 },
    music:    { opacity: 0, x: -20, y: 8 },
    food:     { opacity: 0, y: 22, rotation: -1.5 },
    snacks:   { opacity: 0, scale: 0.88, y: 16 },
    farewell: { opacity: 0, y: 28, rotation: 2 },
  };

  const ITEM_TO: Record<TimelineType, gsap.TweenVars> = {
    church:   { opacity: 1, y: 0, scale: 1, duration: 0.85, ease: EASE.expoOut },
    open:     { opacity: 1, x: 0, scale: 1, duration: 0.75, ease: "back.out(1.4)" },
    music:    { opacity: 1, x: 0, y: 0, duration: 0.7, ease: EASE.expoOut },
    food:     { opacity: 1, y: 0, rotation: 0, duration: 0.8, ease: EASE.inOut },
    snacks:   { opacity: 1, scale: 1, y: 0, duration: 1, ease: "elastic.out(1, 0.65)" },
    farewell: { opacity: 1, y: 0, rotation: 0, duration: 0.9, ease: EASE.expoOut },
  };

  function animateNode(type: TimelineType, node: HTMLElement, icon: SVGElement | null) {
    const tl = gsap.timeline();

    switch (type) {
      case "church":
        tl.fromTo(node, { scale: 0.4, opacity: 0.5 }, { scale: 1, opacity: 1, duration: 0.55, ease: "back.out(2.2)" });
        if (icon) tl.fromTo(icon, { y: -4 }, { y: 0, duration: 0.45, ease: EASE.expoOut }, 0);
        break;
      case "open":
        tl.fromTo(node, { scale: 0.5, x: -10 }, { scale: 1, x: 0, duration: 0.6, ease: "back.out(1.8)" });
        break;
      case "music":
        tl.fromTo(node, { scale: 0.6 }, { scale: 1, duration: 0.5, ease: "back.out(2)" });
        if (icon) tl.fromTo(icon, { rotation: -12 }, { rotation: 0, duration: 0.55, ease: EASE.expoOut }, 0);
        break;
      case "food":
        tl.fromTo(node, { scale: 0.7, rotation: -8 }, { scale: 1, rotation: 0, duration: 0.65, ease: EASE.inOut });
        break;
      case "snacks":
        tl.fromTo(node, { scale: 0.3 }, { scale: 1, duration: 0.85, ease: "elastic.out(1, 0.55)" });
        break;
      case "farewell":
        tl.fromTo(node, { scale: 0.5, rotation: -90 }, { scale: 1, rotation: 0, duration: 0.7, ease: EASE.expoOut });
        if (icon) {
          tl.to(icon, { rotation: 12, duration: 0.35, ease: "sine.inOut", yoyo: true, repeat: 1 }, 0.15);
        }
        break;
    }

    return tl;
  }

  const section = document.querySelector<HTMLElement>("[data-timeline-section]");
  if (section) {
    const header   = section.querySelector<HTMLElement>("[data-tl-header]");
    const lineFill = section.querySelector<HTMLElement>("[data-tl-line]");
    const items    = section.querySelectorAll<HTMLElement>("[data-tl-item]");

    if (prefersReducedMotion) {
      gsap.set([header, ...items], { opacity: 1, y: 0, x: 0, scale: 1, rotation: 0 });
      items.forEach((item) => {
        item.classList.add("is-active");
        const desc = item.querySelector<HTMLElement>("[data-tl-desc]");
        if (desc) gsap.set(desc, { opacity: 1, y: 0 });
      });
      if (lineFill) gsap.set(lineFill, { scaleY: 1 });
    } else {
      gsap.fromTo(
        header,
        { opacity: 0, y: 28 },
        {
          opacity: 1, y: 0, duration: 0.85, ease: EASE.expoOut,
          scrollTrigger: { trigger: section, start: "top 82%", once: true },
        }
      );

      if (lineFill) {
        gsap.to(lineFill, {
          scaleY: 1,
          ease: "none",
          scrollTrigger: {
            trigger: section,
            start: "top 70%",
            end: "bottom 60%",
            scrub: 1,
          },
        });
      }

      items.forEach((item) => {
        const type = (item.dataset.tlType ?? "open") as TimelineType;
        const node = item.querySelector<HTMLElement>("[data-tl-node]");
        const icon = item.querySelector<SVGElement>("[data-tl-icon]");
        const time = item.querySelector<HTMLElement>("[data-tl-time]");
        const title = item.querySelector<HTMLElement>("[data-tl-title]");
        const desc = item.querySelector<HTMLElement>("[data-tl-desc]");
        const content = [time, title].filter(Boolean);

        gsap.set(item, ITEM_FROM[type]);
        if (desc) gsap.set(desc, { opacity: 0, y: 10 });
        if (node) gsap.set(node, { scale: 0.6, opacity: 0.6 });

        const enterTl = gsap.timeline({
          scrollTrigger: {
            trigger: item,
            start: "top 88%",
            once: true,
            onEnter: () => item.classList.add("is-active"),
          },
        });

        enterTl.to(item, ITEM_TO[type], 0);

        if (node) {
          enterTl.add(animateNode(type, node, icon), 0);
        }

        if (content.length) {
          enterTl.fromTo(
            content,
            { opacity: 0, y: 8 },
            { opacity: 1, y: 0, duration: 0.45, stagger: 0.06, ease: EASE.expoOut },
            0.08
          );
        }

        if (desc) {
          enterTl.fromTo(
            desc,
            { opacity: 0, y: 12 },
            { opacity: 1, y: 0, duration: 0.55, ease: EASE.expoOut },
            0.22
          );
        }
      });
    }
  }
</script>
