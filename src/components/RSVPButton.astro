---
import { event } from "../config/event.js";

const { url, label } = event.rsvp;
---

<section
  class="px-6 py-12"
  aria-label="Confirmar asistencia"
  data-rsvp-section
>
  <div class="mx-auto max-w-md">
    <a
      href={url}
      data-anim
      data-rsvp-btn
      class="group relative block w-full overflow-hidden rounded-full bg-leaf-700 py-4 text-center text-base font-semibold text-white shadow-glow transition hover:bg-leaf-800 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-leaf-700 sm:text-lg"
    >
      <!-- Reflejo brillante que cruza el botón -->
      <span
        class="pointer-events-none absolute inset-y-0 -left-1/3 w-1/3 -skew-x-12 bg-white/20 blur-sm transition-transform duration-700 group-hover:translate-x-[400%]"
        aria-hidden="true"
        data-rsvp-shine
      ></span>
      <span class="relative inline-flex items-center justify-center gap-2">
        {label}
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="transition-transform duration-300 group-hover:translate-x-1"
          aria-hidden="true"
        >
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="13 6 19 12 13 18"></polyline>
        </svg>
      </span>
    </a>
  </div>
</section>

<script>
  import { gsap, prefersReducedMotion, EASE } from "../lib/gsap.client.js";

  const btn = document.querySelector<HTMLElement>("[data-rsvp-btn]");
  const shine = document.querySelector<HTMLElement>("[data-rsvp-shine]");
  const section = document.querySelector<HTMLElement>("[data-rsvp-section]");

  if (btn && section) {
    if (prefersReducedMotion) {
      gsap.set(btn, { opacity: 1 });
    } else {
      gsap.fromTo(
        btn,
        { opacity: 0, y: 24, scale: 0.95 },
        {
          opacity: 1,
          y: 0,
          scale: 1,
          duration: 0.9,
          ease: EASE.expoOut,
          scrollTrigger: { trigger: section, start: "top 88%", once: true },
          onComplete: () => {
            // Pase de brillo automático cuando el botón aparece
            if (shine) {
              gsap.fromTo(
                shine,
                { x: 0 },
                { x: "400%", duration: 1.4, ease: "power2.inOut", delay: 0.2 }
              );
            }
          },
        }
      );
    }
  }
</script>