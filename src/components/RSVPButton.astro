---
import { event } from "../config/event.js";

const startISO = event.date;
const endDate  = new Date(startISO);
endDate.setHours(endDate.getHours() + 3);
const endISO = endDate.toISOString().slice(0, 19);

const fmt   = (s: string) => s.replace(/[-:]/g, "").slice(0, 15);
const title = `${event.calendar.title} ${event.calendar.subtitle}`.trim();
const desc  = `¡Acómpañanos a celebrar nuestra boda!`;
const loc   = event.locations.venue.address;

// Google Calendar URL — Android, Windows y demás
const googleURL = [
  "https://calendar.google.com/calendar/render?action=TEMPLATE",
  `&text=${encodeURIComponent(title)}`,
  `&dates=${fmt(startISO)}/${fmt(endISO)}`,
  `&details=${encodeURIComponent(desc)}`,
  `&location=${encodeURIComponent(loc)}`,
].join("");

const label = event.rsvp.label;
---

<section
  class="px-6 py-16 sm:py-20"
  aria-labelledby="rsvp-title"
  data-rsvp-section
>
  <div class="mx-auto max-w-md text-center">

    <!-- Section header -->
    <p class="font-sans text-[9px] font-bold uppercase tracking-[0.45em] text-chrome-500">
      ¿Nos acompañas?
    </p>
    <h2
      id="rsvp-title"
      class="font-vibes mt-1 text-5xl leading-tight text-chrome-800 sm:text-6xl"
    >
      Confirma tu Asistencia
    </h2>
    <p class="mx-auto mt-3 mb-8 max-w-[28ch] font-script text-sm italic text-chrome-600 text-balance">
      Guarda la fecha en tu calendario
    </p>

    <a
      id="cal-btn"
      data-anim
      data-rsvp-btn
      href={googleURL}
      target="_blank"
      rel="noopener noreferrer"
      class="group relative block w-full overflow-hidden rounded-full bg-leaf-700 py-4 text-center text-base font-semibold text-white shadow-glow transition hover:bg-leaf-800 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-leaf-700 sm:text-lg"
      aria-label="Agregar el evento al calendario"
    >
      <!-- Shine effect -->
      <span
        class="pointer-events-none absolute inset-y-0 -left-1/3 w-1/3 -skew-x-12 bg-white/20 blur-sm transition-transform duration-700 group-hover:translate-x-[400%]"
        aria-hidden="true"
        data-rsvp-shine
      ></span>

      <span class="relative inline-flex items-center justify-center gap-2">
        {label}

        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="transition-transform duration-300 group-hover:translate-x-1"
          aria-hidden="true"
        >
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="13 6 19 12 13 18"></polyline>
        </svg>
      </span>
    </a>

    <p
      id="cal-hint"
      class="mt-3 text-center text-xs text-chrome-400"
      aria-live="polite"
    ></p>

  </div>
</section>

<script define:vars={{ googleURL }}>
  const btn  = document.getElementById("cal-btn");
  const hint = document.getElementById("cal-hint");
  const isApple = /iphone|ipad|ipod|macintosh/i.test(navigator.userAgent);

  if (isApple) {
    // iOS/macOS: el archivo .ics es interceptado por el sistema y abre Apple Calendario
    btn?.setAttribute("href", "/evento.ics");
    btn?.removeAttribute("target");
    btn?.removeAttribute("rel");
    if (hint) hint.textContent = "Se abrirá Apple Calendario.";
  } else {
    btn?.setAttribute("href", googleURL);
    if (hint) hint.textContent = "Se abrirá Google Calendar.";
  }
</script>

<script>
  import { gsap, prefersReducedMotion, EASE } from "../lib/gsap.client.js";

  const btn = document.querySelector("[data-rsvp-btn]");
  const shine = document.querySelector("[data-rsvp-shine]");
  const section = document.querySelector("[data-rsvp-section]");

  if (btn && section) {
    if (prefersReducedMotion) {
      gsap.set(btn, { opacity: 1 });
    } else {
      gsap.fromTo(
        btn,
        { opacity: 0, y: 24, scale: 0.95 },
        {
          opacity: 1,
          y: 0,
          scale: 1,
          duration: 0.9,
          ease: EASE.expoOut,
          scrollTrigger: {
            trigger: section,
            start: "top 88%",
            once: true,
          },
          onComplete: () => {
            if (shine) {
              gsap.fromTo(
                shine,
                { x: 0 },
                {
                  x: "400%",
                  duration: 1.4,
                  ease: "power2.inOut",
                  delay: 0.2,
                }
              );
            }
          },
        }
      );
    }
  }
</script>
