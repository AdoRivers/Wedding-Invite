---
import { event } from "../config/event.js";
---

<section
  id="hero"
  class="relative flex min-h-svh w-full flex-col bg-white"
  aria-labelledby="hero-title"
>

  <!-- ══════════════════ GUIRNALDA ══════════════════ -->
  <div class="garland relative z-30 h-16 w-full shrink-0 overflow-visible sm:h-20 -mb-16 sm:-mb-20" aria-hidden="true">
    <svg class="absolute inset-0 h-full w-full" viewBox="0 0 390 56" preserveAspectRatio="none">
      <path d="M-10 8 Q55 38 120 12 Q195 -8 270 16 Q330 36 400 10"
        fill="none" stroke="#D4AF37" stroke-width="1" opacity="0.7"/>
    </svg>
    <div class="g-item absolute origin-top" style="left:3%;  top:0px;"  data-sw="a"><svg viewBox="0 0 80 80" width="46" height="46"><use href="#s5"/></svg></div>
    <div class="g-item absolute origin-top" style="left:13%; top:14px;" data-sw="b"><svg viewBox="0 0 100 118" width="40" height="48"><line x1="50" y1="0" x2="50" y2="16" stroke="#D4AF37" stroke-width="1.2"/><use href="#db" x="0" y="16" width="100" height="100"/></svg></div>
    <div class="g-item absolute origin-top" style="left:25%; top:2px;"  data-sw="a"><svg viewBox="0 0 80 80" width="42" height="42"><use href="#s5"/></svg></div>
    <div class="g-item absolute origin-top" style="left:37%; top:10px;" data-sw="c"><svg viewBox="0 0 100 118" width="38" height="46"><line x1="50" y1="0" x2="50" y2="16" stroke="#D4AF37" stroke-width="1.2"/><use href="#db" x="0" y="16" width="100" height="100"/></svg></div>
    <div class="g-item absolute origin-top" style="left:49%; top:0px;"  data-sw="b"><svg viewBox="0 0 80 80" width="44" height="44"><use href="#s5"/></svg></div>
    <div class="g-item absolute origin-top" style="left:61%; top:12px;" data-sw="a"><svg viewBox="0 0 100 118" width="36" height="44"><line x1="50" y1="0" x2="50" y2="16" stroke="#D4AF37" stroke-width="1.2"/><use href="#db" x="0" y="16" width="100" height="100"/></svg></div>
    <div class="g-item absolute origin-top" style="left:73%; top:2px;"  data-sw="c"><svg viewBox="0 0 80 80" width="40" height="40"><use href="#s5"/></svg></div>
    <div class="g-item absolute origin-top" style="left:83%; top:8px;"  data-sw="b"><svg viewBox="0 0 100 118" width="36" height="44"><line x1="50" y1="0" x2="50" y2="16" stroke="#D4AF37" stroke-width="1.2"/><use href="#db" x="0" y="16" width="100" height="100"/></svg></div>
    <div class="g-item absolute origin-top" style="left:93%; top:0px;"  data-sw="a"><svg viewBox="0 0 80 80" width="38" height="38"><use href="#s5"/></svg></div>
  </div>

  <!-- ══════════════════ STAGE ══════════════════ -->
  <div class="stage relative flex-1 overflow-visible">

    <img
      src={event.couple.portrait}
      alt="Cover"
      aria-hidden="true"
      class="absolute inset-0 h-full w-full object-cover object-bottom sm:object-center"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />

    <!-- Top gradient for text legibility -->
    <div class="absolute inset-x-0 top-0 h-[60%] bg-linear-to-b from-white/96 via-white/60 to-transparent pointer-events-none" aria-hidden="true"></div>
    <!-- Bottom fade -->
    <div class="absolute inset-x-0 bottom-0 h-[22%] bg-linear-to-t from-white to-transparent pointer-events-none" aria-hidden="true"></div>

    <h1 id="hero-title" class="sr-only">{event.hero.eyebrow} {event.hero.title}</h1>

  </div>

  <!-- ══════════════════ PILLS ══════════════════ -->
  <div class="hero-copy relative z-20 flex justify-center pb-8 pt-4 px-6">
    <div class="inline-flex items-center gap-2.5 rounded-full border border-chrome-300/80 bg-white/85 px-5 py-2 backdrop-blur-sm">
      <span class="font-sans text-[9.5px] font-bold uppercase tracking-[0.22em] text-chrome-600">
        {event.dateLabel.day} {event.dateLabel.month} 2026
      </span>
      <span class="h-3.5 w-px bg-chrome-300" aria-hidden="true"></span>
      <span class="font-sans text-[9.5px] font-bold uppercase tracking-[0.22em] text-chrome-600">
        {event.timeLabel}
      </span>
    </div>
  </div>

  <!-- SVG SYMBOLS -->
  <svg class="absolute size-0 overflow-hidden" aria-hidden="true">
    <defs>
      <!-- Estrella dorada de 5 puntas -->
      <symbol id="s5" viewBox="0 0 80 80">
        <defs>
          <radialGradient id="s5g" cx="30%" cy="24%" r="74%">
            <stop offset="0%"   stop-color="#fffde7"/>
            <stop offset="40%"  stop-color="#d4af37"/>
            <stop offset="100%" stop-color="#8b6914"/>
          </radialGradient>
        </defs>
        <path d="M40 5 L50 28 L76 28 L55 44 L63 68 L40 53 L17 68 L25 44 L4 28 L30 28 Z" fill="url(#s5g)" stroke="rgba(255,240,150,0.4)" stroke-width="0.8"/>
        <ellipse cx="31" cy="25" rx="8" ry="4.5" fill="rgba(255,255,255,0.45)" transform="rotate(-26 31 25)"/>
        <ellipse cx="25" cy="21" rx="4" ry="2.5" fill="rgba(255,255,255,0.70)" transform="rotate(-26 25 21)"/>
      </symbol>
      <!-- Anillo nupcial dorado -->
      <symbol id="db" viewBox="0 0 100 100">
        <defs>
          <radialGradient id="dbg" cx="35%" cy="28%" r="66%">
            <stop offset="0%"   stop-color="#fffde7"/>
            <stop offset="40%"  stop-color="#d4af37"/>
            <stop offset="100%" stop-color="#7a5500"/>
          </radialGradient>
          <radialGradient id="dbi" cx="35%" cy="28%" r="66%">
            <stop offset="0%"   stop-color="#fdfbf0"/>
            <stop offset="100%" stop-color="#c9a227"/>
          </radialGradient>
        </defs>
        <circle cx="50" cy="50" r="40" fill="none" stroke="url(#dbg)" stroke-width="16"/>
        <circle cx="50" cy="50" r="40" fill="none" stroke="url(#dbi)" stroke-width="4" stroke-dasharray="40 210" stroke-dashoffset="-30"/>
        <ellipse cx="28" cy="34" rx="9" ry="4.5" fill="white" opacity="0.50" transform="rotate(-30 28 34)"/>
        <ellipse cx="22" cy="28" rx="5" ry="2.5" fill="white" opacity="0.78" transform="rotate(-30 22 28)"/>
      </symbol>
    </defs>
  </svg>

</section>

<style>
.garland { position: relative; z-index: 30; }

.stage {
  min-height: 65vw;
}
.stage > img {
  clip-path: inset(0);
}
@media (min-width: 640px) {
  .stage { min-height: 420px; }
}
@media (min-width: 768px) {
  .stage { min-height: 520px; }
}

@media (prefers-reduced-motion: no-preference) {
  .g-item             { animation: swing 4.5s ease-in-out infinite; }
  .g-item[data-sw="b"]{ animation-duration: 5.5s; animation-delay: 0.5s; }
  .g-item[data-sw="c"]{ animation-duration: 3.8s; animation-delay: 1s; }
}
@keyframes swing {
  0%, 100% { transform: rotate(-2.5deg); }
  50%       { transform: rotate(2.5deg); }
}
</style>

<script>
  import { gsap, prefersReducedMotion, EASE } from "../lib/gsap.client.js";

  const hero = document.getElementById("hero");
  if (hero) {
    const garland  = hero.querySelector<HTMLElement>(".garland");
    const heroBg   = hero.querySelector<HTMLImageElement>(".stage img");
    const heroCopy = hero.querySelector<HTMLElement>(".hero-copy");

    if (prefersReducedMotion) {
      gsap.set([garland, heroBg, heroCopy], { opacity: 1, y: 0, scale: 1 });
    } else {
      gsap.set(garland,  { opacity: 0, y: -28 });
      gsap.set(heroBg,   { opacity: 0, scale: 1.04 });
      gsap.set(heroCopy, { opacity: 0, y: 10 });

      gsap.timeline({ delay: 0.06 })
        .to(garland,  { opacity: 1, y: 0, duration: 0.7, ease: "back.out(1.5)" })
        .to(heroBg,   { opacity: 1, scale: 1, duration: 1.1, ease: "power2.out" }, "-=0.4")
        .to(heroCopy, { opacity: 1, y: 0, duration: 0.6, ease: EASE.out }, "-=0.3");
    }
  }
</script>
