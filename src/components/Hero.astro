---
import { event } from "../config/event.js";
---

<section
  id="hero"
  class="relative flex min-h-svh w-full flex-col bg-white"
  aria-labelledby="hero-title"
>

  <!-- ══════════════════ GUIRNALDA — se superpone sobre la imagen ══════════════════ -->
  <div class="garland relative z-10 h-16 w-full shrink-0 overflow-visible sm:h-20 -mb-16 sm:-mb-20" aria-hidden="true">
    <svg class="absolute inset-0 h-full w-full" viewBox="0 0 390 56" preserveAspectRatio="none">
      <path d="M-10 8 Q55 38 120 12 Q195 -8 270 16 Q330 36 400 10"
        fill="none" stroke="#c0c0c8" stroke-width="1" opacity="0.6"/>
    </svg>
    <div class="g-item absolute origin-top" style="left:3%;  top:0px;"  data-sw="a"><svg viewBox="0 0 80 80" width="46" height="46"><use href="#s5"/></svg></div>
    <div class="g-item absolute origin-top" style="left:13%; top:14px;" data-sw="b"><svg viewBox="0 0 100 118" width="40" height="48"><line x1="50" y1="0" x2="50" y2="16" stroke="#c0c0c8" stroke-width="1.2"/><use href="#db" x="0" y="16" width="100" height="100"/></svg></div>
    <div class="g-item absolute origin-top" style="left:25%; top:2px;"  data-sw="a"><svg viewBox="0 0 80 80" width="42" height="42"><use href="#s5"/></svg></div>
    <div class="g-item absolute origin-top" style="left:37%; top:10px;" data-sw="c"><svg viewBox="0 0 100 118" width="38" height="46"><line x1="50" y1="0" x2="50" y2="16" stroke="#c0c0c8" stroke-width="1.2"/><use href="#db" x="0" y="16" width="100" height="100"/></svg></div>
    <div class="g-item absolute origin-top" style="left:49%; top:0px;"  data-sw="b"><svg viewBox="0 0 80 80" width="44" height="44"><use href="#s5"/></svg></div>
    <div class="g-item absolute origin-top" style="left:61%; top:12px;" data-sw="a"><svg viewBox="0 0 100 118" width="36" height="44"><line x1="50" y1="0" x2="50" y2="16" stroke="#c0c0c8" stroke-width="1.2"/><use href="#db" x="0" y="16" width="100" height="100"/></svg></div>
    <div class="g-item absolute origin-top" style="left:73%; top:2px;"  data-sw="c"><svg viewBox="0 0 80 80" width="40" height="40"><use href="#s5"/></svg></div>
    <div class="g-item absolute origin-top" style="left:83%; top:8px;"  data-sw="b"><svg viewBox="0 0 100 118" width="36" height="44"><line x1="50" y1="0" x2="50" y2="16" stroke="#c0c0c8" stroke-width="1.2"/><use href="#db" x="0" y="16" width="100" height="100"/></svg></div>
    <div class="g-item absolute origin-top" style="left:93%; top:0px;"  data-sw="a"><svg viewBox="0 0 80 80" width="38" height="38"><use href="#s5"/></svg></div>
  </div>

  <!-- ══════════════════ STAGE — imagen de fondo ══════════════════ -->
  <div class="stage relative flex-1 overflow-visible">

    <!-- Imagen de fondo festiva -->
    <img
      src="/images/hero-bg.svg"
      alt=""
      aria-hidden="true"
      class="absolute inset-0 h-full w-full object-cover object-bottom sm:object-center"
      loading="eager"
      fetchpriority="high"
      decoding="async"
    />

    <!-- Degradado superior: muy sutil, solo para legibilidad del texto -->
    <div class="absolute inset-x-0 top-0 h-[35%] bg-gradient-to-b from-white/60 to-transparent pointer-events-none" aria-hidden="true"></div>
    <!-- Degradado inferior: leve transición al blanco -->
    <div class="absolute inset-x-0 bottom-0 h-[20%] bg-gradient-to-t from-white/70 to-transparent pointer-events-none" aria-hidden="true"></div>

    <!-- Texto en arco sobre el degradado superior -->
    <div class="arc-text pointer-events-none absolute inset-x-0 top-0 z-20 flex items-start justify-center pt-4" aria-hidden="true">
      <svg viewBox="0 0 360 160" class="w-full max-w-[500px]" preserveAspectRatio="xMidYMin meet">
        <defs>
          <path id="ae" d="M 40,100 A 260,260 0 0,1 320,100" fill="none"/>
          <path id="at" d="M   0,158 A 340,340 0 0,1 360,158" fill="none"/>
        </defs>
        <text font-family="var(--font-sans),sans-serif" font-weight="700" letter-spacing="0.35em" text-anchor="middle" fill="var(--color-chrome-400)" font-size="22">
          <textPath href="#ae" startOffset="50%">{event.hero.eyebrow.toUpperCase()}</textPath>
        </text>
        <text font-family="var(--font-sans),sans-serif" font-weight="900" letter-spacing="-0.01em" text-anchor="middle" fill="var(--color-chrome-900)" font-size="58">
          <textPath href="#at" startOffset="50%">{event.hero.title.toUpperCase()}</textPath>
        </text>
      </svg>
    </div>

    <!-- h1 semántico -->
    <h1 id="hero-title" class="sr-only">{event.hero.eyebrow} {event.hero.title}</h1>

  </div><!-- /stage -->

  <!-- ══════════════════ PILLS ══════════════════ -->
  <div class="relative z-20 px-5 pt-3 pb-5">
    <div class="flex flex-wrap justify-center gap-1.5">
      <span class="rounded-full bg-leaf-100 px-3.5 py-1.5 font-sans text-[9.5px] font-bold tracking-[0.18em] uppercase text-current">
        {event.dateLabel.short}
      </span>
      <span class="rounded-full border border-chrome-300 px-3.5 py-1.5 font-sans text-[9.5px] font-bold tracking-[0.18em] uppercase text-chrome-600">
        {event.timeLabel}
      </span>
      <span class="rounded-full border border-chrome-300 px-3.5 py-1.5 font-sans text-[9.5px] font-bold tracking-[0.18em] uppercase text-chrome-600">
        Black &amp; White
      </span>
    </div>
  </div>

  <!-- Recordatorio regalo -->
  <div class="z-20 flex flex-col items-center gap-1 py-4 pb-6">
    <p class="font-sans text-[11px] font-semibold uppercase tracking-[0.3em] text-chrome-400">
      no olvides mi regalo
    </p>
    <p class="text-xl" aria-hidden="true">🎁 &nbsp; 📩</p>
  </div>

  <!-- SVG SYMBOLS -->
  <svg class="absolute size-0 overflow-hidden" aria-hidden="true">
    <defs>
      <symbol id="s5" viewBox="0 0 80 80">
        <defs>
          <radialGradient id="s5g" cx="30%" cy="24%" r="74%">
            <stop offset="0%"   stop-color="#f4f4f5"/>
            <stop offset="40%"  stop-color="#a8a8b4"/>
            <stop offset="100%" stop-color="#3c3c48"/>
          </radialGradient>
        </defs>
        <path d="M40 5 L50 28 L76 28 L55 44 L63 68 L40 53 L17 68 L25 44 L4 28 L30 28 Z" fill="url(#s5g)" stroke="rgba(255,255,255,0.3)" stroke-width="0.8"/>
        <ellipse cx="31" cy="25" rx="8" ry="4.5" fill="rgba(255,255,255,0.42)" transform="rotate(-26 31 25)"/>
        <ellipse cx="25" cy="21" rx="4" ry="2.5" fill="rgba(255,255,255,0.65)" transform="rotate(-26 25 21)"/>
      </symbol>
      <symbol id="db" viewBox="0 0 100 100">
        <defs>
          <radialGradient id="dbg" cx="34%" cy="28%" r="66%">
            <stop offset="0%"   stop-color="#fff" stop-opacity="0.95"/>
            <stop offset="36%"  stop-color="#d0d0d8"/>
            <stop offset="100%" stop-color="#484854"/>
          </radialGradient>
          <clipPath id="dbc"><circle cx="50" cy="50" r="44"/></clipPath>
          <pattern id="dbp" width="12" height="12" patternUnits="userSpaceOnUse">
            <rect width="11" height="11" rx="1.2" fill="url(#dbg)" opacity="0.9"/>
          </pattern>
        </defs>
        <circle cx="50" cy="50" r="44" fill="#232330"/>
        <circle cx="50" cy="50" r="44" fill="url(#dbp)" clip-path="url(#dbc)"/>
        <ellipse cx="33" cy="31" rx="11" ry="7" fill="white" opacity="0.45" transform="rotate(-26 33 31)"/>
        <ellipse cx="26" cy="25" rx="5"  ry="3"  fill="white" opacity="0.75" transform="rotate(-26 26 25)"/>
        <circle  cx="50" cy="50" r="44"  fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
      </symbol>
    </defs>
  </svg>

</section>

<style>
/* Guirnalda se superpone sobre la imagen */
.garland { position: relative; z-index: 10; }

/* Stage: altura mínima según breakpoint */
.stage {
  min-height: 65vw;
  /* Clip solo la imagen interna, no el contenido que sobresale (guirnalda) */
}
.stage > img {
  clip-path: inset(0);   /* recorta la imagen al stage sin afectar elementos z superiores */
}
@media (min-width: 640px) {
  .stage { min-height: 420px; }
}
@media (min-width: 768px) {
  .stage { min-height: 520px; }
}


/* Guirnalda swing */
@media (prefers-reduced-motion: no-preference) {
  .g-item             { animation: swing 4.5s ease-in-out infinite; }
  .g-item[data-sw="b"]{ animation-duration: 5.5s; animation-delay: 0.5s; }
  .g-item[data-sw="c"]{ animation-duration: 3.8s; animation-delay: 1s; }
}
@keyframes swing {
  0%, 100% { transform: rotate(-2.5deg); }
  50%       { transform: rotate(2.5deg); }
}
</style>

<script>
  import { gsap, prefersReducedMotion, EASE } from "../lib/gsap.client.js";

  const hero = document.getElementById("hero");
  if (hero) {
    const garland = hero.querySelector<HTMLElement>(".garland");
    const heroBg  = hero.querySelector<HTMLImageElement>(".stage img");
    const arcText = hero.querySelector<HTMLElement>(".arc-text");
    const pills   = hero.querySelectorAll<HTMLElement>("[class*='rounded-full']");

    if (prefersReducedMotion) {
      gsap.set([garland, heroBg, arcText, pills], { opacity: 1, y: 0, scale: 1 });
    } else {
      gsap.set(garland,  { opacity: 0, y: -28 });
      gsap.set(heroBg,   { opacity: 0, scale: 1.04 });
      gsap.set(arcText,  { opacity: 0 });
      gsap.set(pills,    { opacity: 0, y: 12 });

      gsap.timeline({ delay: 0.06 })
        .to(garland,  { opacity: 1, y: 0, duration: 0.7, ease: "back.out(1.5)" })
        .to(heroBg,   { opacity: 1, scale: 1, duration: 1.1, ease: "power2.out" }, "-=0.4")
        .to(arcText,  { opacity: 1, duration: 0.7, ease: EASE.out }, "-=0.5")
        .to(pills,    { opacity: 1, y: 0, duration: 0.45, stagger: 0.08, ease: EASE.out }, "-=0.2");
    }
  }
</script>