---
import { event } from "./event.js";
---

<section class="flex flex-col items-center text-center" aria-labelledby="hero-title">
  <!-- Disco con la invitación impresa -->
  <div class="relative mt-4 flex aspect-square w-64 items-center justify-center rounded-full bg-pink-100/70 shadow-card sm:w-80">
    <div class="absolute inset-3 rounded-full bg-gradient-to-br from-pink-100 to-pink-200/80"></div>
    <div class="relative z-10 flex flex-col items-center gap-2 px-6 py-8">
      <p class="font-title text-2xl text-pink-700 sm:text-3xl">{event.honoree.name}</p>

      <div class="size-20 overflow-hidden rounded-full border-4 border-white shadow-soft sm:size-24">
        <img
          src={event.honoree.photo}
          alt={`Foto de ${event.honoree.name}`}
          class="h-full w-full object-cover"
          loading="eager"
          decoding="async"
        />
      </div>

      <p class="max-w-[12rem] text-[0.7rem] italic text-pink-700/90 sm:text-xs">
        {event.message}
      </p>

      <div class="mt-1 flex items-center gap-3 text-pink-800">
        <div class="flex flex-col leading-none">
          <span class="text-xl font-bold sm:text-2xl">{event.dateLabel.day}</span>
          <span class="text-[0.6rem] uppercase tracking-widest">{event.dateLabel.month}</span>
        </div>
        <span class="h-8 w-px bg-pink-300" aria-hidden="true"></span>
        <div class="flex flex-col leading-none">
          <span class="text-xl font-bold sm:text-2xl">{event.timeLabel.hours.split(":")[0]}</span>
          <span class="text-[0.6rem] uppercase tracking-widest">Horas</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Título principal -->
  <h1 id="hero-title" class="mt-8 font-title text-5xl text-primary sm:text-6xl">
    {event.title}
  </h1>
  <p class="mt-1 text-xs uppercase tracking-[0.3em] text-primary/80 sm:text-sm">
    {event.subtitle}
  </p>

  <!-- Chips de fecha y hora -->
  <div class="mt-6 flex items-center gap-3">
    <span class="rounded-full bg-secondary/60 px-5 py-2 text-xs font-semibold uppercase tracking-wider text-primary sm:text-sm">
      {event.dateLabel.month.slice(0, 3)} {event.dateLabel.day}
    </span>
    <span class="rounded-full border border-secondary/60 bg-surface px-5 py-2 text-xs font-semibold uppercase tracking-wider text-primary sm:text-sm">
      {event.timeLabel.hours} {event.timeLabel.suffix}
    </span>
  </div>
</section>