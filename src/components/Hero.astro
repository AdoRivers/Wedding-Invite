---
import { event } from "../config/event.js";
---

<section
  class="relative flex h-svh min-h-[640px] w-full items-center justify-center overflow-hidden"
  aria-labelledby="hero-title"
>
  <!-- Imagen de fondo -->
  <img
    src={event.honoree.portrait}
    alt={`Retrato de ${event.honoree.name}`}
    class="absolute inset-0 h-full w-full object-cover object-center"
    loading="eager"
    fetchpriority="high"
    decoding="async"
  />

  <!-- Degradado: oscurece arriba/abajo, blanco al final para fundir con el resto -->
  <div
    class="absolute inset-0 bg-gradient-to-b from-black/30 via-transparent to-canvas"
    aria-hidden="true"
  ></div>

  <!-- Contenido -->
  <div class="relative z-10 flex min-h-screen flex-col items-center justify-end px-6 pb-24 text-center md:justify-center md:pb-0"">
    <h1
      id="hero-title"
      class="font-vibes text-6xl italic font-medium leading-none text-white drop-shadow-md sm:text-7xl md:text-8xl"
    >
      {event.title}
    </h1>

    <p class="mt-3 text-xs uppercase tracking-[0.4em] text-white/90 sm:text-sm">
      {event.subtitle}
    </p>

    <div class="mt-8 flex flex-col items-center gap-3 sm:flex-row">
      <span class="rounded-full bg-leaf-300 px-6 py-2 text-xs font-semibold uppercase tracking-widest text-leaf-800 shadow-soft">
        {event.dateLabel.short}
      </span>
      <span class="rounded-full border border-white/70 bg-white/95 px-6 py-2 text-xs font-semibold uppercase tracking-widest text-leaf-800 shadow-soft">
        {event.timeLabel}
      </span>
    </div>
  </div>

  <!-- Indicador de scroll -->
  <a
    href="#countdown"
    aria-label="Ir al contenido"
    class="absolute bottom-8 left-1/2 z-10 -translate-x-1/2 text-white/80 transition hover:text-white"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="28"
      height="28"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="animate-bounce"
    >
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </a>
</section>