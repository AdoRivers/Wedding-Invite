---
import { event } from "../config/event.js";

const locations = [
  {
    ...event.locations.church,
    icon: "church",
  },
  {
    ...event.locations.venue,
    icon: "pin",
  },
];

function buildUrls(mapsQuery: string) {
  const encoded = encodeURIComponent(mapsQuery);
  return {
    mapsUrl: `https://www.google.com/maps/search/?api=1&query=${encoded}`,
    embedUrl: `https://www.google.com/maps?q=${encoded}&output=embed`,
  };
}
---

<section
  class="px-6 py-8 space-y-10"
  aria-labelledby="location-section-title"
  data-location
>
  <div class="mx-auto max-w-md">
    <p class="mb-1 font-sans text-[9.5px] font-semibold uppercase tracking-[0.4em] text-chrome-400">
      ¿Dónde?
    </p>
    <h2
      id="location-section-title"
      class="font-sans text-2xl font-black uppercase tracking-tight text-chrome-900 sm:text-3xl"
    >
      Locaciones
    </h2>
    <div class="mt-3 h-[2px] w-10 bg-chrome-900" aria-hidden="true"></div>
  </div>

  {locations.map(({ label, name, address, mapsQuery, icon }) => {
    const { mapsUrl, embedUrl } = buildUrls(mapsQuery);
    return (
      <div class="mx-auto max-w-md" data-anim>
        <!-- Eyebrow + encabezado -->
        <div class="flex items-start gap-3 mb-5">
          <span
            class="grid size-11 place-items-center rounded-xl bg-leaf-100 text-leaf-700 shadow-soft shrink-0"
            aria-hidden="true"
          >
            {icon === "church" ? (
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m18 7 4 2v11a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V9l4-2"/>
                <path d="M14 22v-4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v4"/>
                <path d="M18 22V5l-6-3-6 3v17"/>
                <path d="M12 7v5"/>
                <path d="M10 9h4"/>
              </svg>
            ) : (
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M20 10c0 7-8 13-8 13s-8-6-8-13a8 8 0 0 1 16 0Z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            )}
          </span>
          <div>
            <p class="text-[9px] font-semibold uppercase tracking-[0.35em] text-leaf-600 mb-0.5">
              {label}
            </p>
            <h3 class="text-base font-semibold text-leaf-800">{name}</h3>
            <p class="text-sm text-muted">{address}</p>
          </div>
        </div>

        <!-- Mapa -->
        <div
          class="relative overflow-hidden rounded-card-lg shadow-card ring-1 ring-leaf-200/60"
          data-map-frame
        >
          <iframe
            src={embedUrl}
            title={`Mapa: ${name}`}
            class="block h-56 w-full sm:h-64"
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>

          <a
            href={mapsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="absolute right-4 bottom-4 inline-flex items-center gap-2 rounded-full bg-white px-4 py-2 text-sm font-medium text-leaf-700 shadow-card transition hover:scale-105 hover:bg-leaf-50"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <polygon points="12 2 22 8.5 12 15 2 8.5 12 2"/>
              <polyline points="2 15.5 12 22 22 15.5"/>
            </svg>
            Abrir en Maps
          </a>
        </div>
      </div>
    );
  })}
</section>

<script>
  import { gsap, prefersReducedMotion, EASE } from "../lib/gsap.client.js";

  const section = document.querySelector<HTMLElement>("[data-location]");
  if (section) {
    const items = section.querySelectorAll<HTMLElement>("[data-anim]");
    if (prefersReducedMotion) {
      gsap.set(items, { opacity: 1 });
    } else {
      gsap.fromTo(
        items,
        { opacity: 0, y: 30 },
        {
          opacity: 1,
          y: 0,
          duration: 0.85,
          ease: EASE.expoOut,
          stagger: 0.22,
          scrollTrigger: { trigger: section, start: "top 85%", once: true },
        }
      );
    }
  }
</script>
