---
import { event } from "../config/event.js";

const { name, address, mapsQuery } = event.location;
const encodedQuery = encodeURIComponent(mapsQuery);
const mapsUrl = `https://www.google.com/maps/search/?api=1&query=${encodedQuery}`;
const embedUrl = `https://www.google.com/maps?q=${encodedQuery}&output=embed`;
---

<section
  class="px-6 py-8"
  aria-labelledby="location-title"
  data-location
>
  <div class="mx-auto max-w-md">
    <!-- Encabezado -->
    <div class="flex items-start gap-3" data-anim>
      <span
        class="grid size-11 place-items-center rounded-xl bg-leaf-100 text-leaf-700 shadow-soft"
        aria-hidden="true"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 10c0 7-8 13-8 13s-8-6-8-13a8 8 0 0 1 16 0Z"></path>
          <circle cx="12" cy="10" r="3"></circle>
        </svg>
      </span>
      <div>
        <h2 id="location-title" class="text-base font-semibold text-leaf-800">{name}</h2>
        <p class="text-sm text-muted">{address}</p>
      </div>
    </div>

    <!-- Mapa real (iframe) + CTA -->
    <div
      class="relative mt-5 overflow-hidden rounded-card-lg shadow-card ring-1 ring-leaf-200/60"
      data-anim
      data-map-frame
    >
      <iframe
        src={embedUrl}
        title={`Mapa: ${name}`}
        class="block h-56 w-full sm:h-64"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen
      ></iframe>

      <a
        href={mapsUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="absolute right-4 bottom-4 inline-flex items-center gap-2 rounded-full bg-white px-4 py-2 text-sm font-medium text-leaf-700 shadow-card transition hover:scale-105 hover:bg-leaf-50"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polygon points="12 2 22 8.5 12 15 2 8.5 12 2"></polygon>
          <polyline points="2 15.5 12 22 22 15.5"></polyline>
        </svg>
        Abrir en Maps
      </a>
    </div>
  </div>
</section>

<script>
  import { gsap, prefersReducedMotion, EASE } from "../lib/gsap.client.js";

  const section = document.querySelector<HTMLElement>("[data-location]");
  if (section) {
    const items = section.querySelectorAll<HTMLElement>("[data-anim]");
    if (prefersReducedMotion) {
      gsap.set(items, { opacity: 1 });
    } else {
      gsap.fromTo(
        items,
        { opacity: 0, y: 30 },
        {
          opacity: 1,
          y: 0,
          duration: 0.85,
          ease: EASE.expoOut,
          stagger: 0.18,
          scrollTrigger: { trigger: section, start: "top 85%", once: true },
        }
      );
    }
  }
</script>