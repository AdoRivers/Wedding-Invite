---
interface Props {
  label: string;
  title: string;
  description: string;
  image: string;
  icon: "sparkles" | "hanger";
  variant?: "soft" | "white";
  /** id único para enlazar checkbox y label */
  id: string;
}

const { label, title, description, image, icon, variant = "soft", id } = Astro.props;

const frontVariant =
  variant === "soft" ? "bg-leaf-100" : "bg-surface ring-1 ring-leaf-100";
---

<div
  class="group relative aspect-[4/5] [perspective:1200px]"
  data-anim
  data-info-card
>
  <input
    type="checkbox"
    id={id}
    class="peer sr-only"
    aria-label={`Ver imagen de ${title}`}
  />

  <label
    for={id}
    class="block h-full w-full cursor-pointer select-none [transform-style:preserve-3d] transition-transform duration-700 ease-[cubic-bezier(0.22,1,0.36,1)] peer-checked:[transform:rotateY(180deg)] peer-focus-visible:outline-2 peer-focus-visible:outline-offset-4 peer-focus-visible:outline-leaf-700 motion-reduce:transition-none"
  >
    <!-- ---------- FRONT ---------- -->
    <div
      class={`absolute inset-0 flex flex-col items-center justify-center overflow-hidden rounded-card-lg p-6 text-center [backface-visibility:hidden] sm:p-8 ${frontVariant}`}
    >
      <!-- Decoración: anillo concéntrico sutil -->
      <span
        class="pointer-events-none absolute -right-8 -top-8 size-32 rounded-full border border-leaf-200/60"
        aria-hidden="true"
      ></span>
      <span
        class="pointer-events-none absolute -left-10 -bottom-10 size-28 rounded-full border border-leaf-200/40"
        aria-hidden="true"
      ></span>

      <span
        class="grid size-12 place-items-center rounded-full bg-white text-leaf-700 shadow-soft"
        aria-hidden="true"
      >
        {icon === "sparkles" && (
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3v3M12 18v3M3 12h3M18 12h3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M5.6 18.4l2.1-2.1M16.3 7.7l2.1-2.1"></path>
            <circle cx="12" cy="12" r="2.5"></circle>
          </svg>
        )}
        {icon === "hanger" && (
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 7a2 2 0 1 1 2-2"></path>
            <path d="M12 7v2"></path>
            <path d="M12 9 3 16h18z"></path>
          </svg>
        )}
      </span>

      <p class="relative mt-4 text-[0.65rem] uppercase tracking-[0.3em] text-leaf-700/80">
        {label}
      </p>
      <h3 class="relative mt-2 font-script text-3xl italic text-leaf-800 sm:text-4xl">
        {title}
      </h3>
      <p class="relative mt-3 max-w-[22ch] text-sm text-leaf-800/75 text-balance">
        {description}
      </p>

      <span class="relative mt-5 inline-flex items-center gap-1.5 rounded-full bg-white/80 px-3 py-1.5 text-[0.6rem] uppercase tracking-widest text-leaf-700 shadow-soft">
        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12a9 9 0 1 1-3-6.7"></path>
          <polyline points="21 4 21 10 15 10"></polyline>
        </svg>
        Voltear
      </span>
    </div>

    <!-- ---------- BACK ---------- -->
    <div
      class="absolute inset-0 overflow-hidden rounded-card-lg [backface-visibility:hidden] [transform:rotateY(180deg)]"
    >
      <img
        src={image}
        alt={`Referencia visual de ${title}`}
        loading="lazy"
        decoding="async"
        class="absolute inset-0 h-full w-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-leaf-900/90 via-leaf-900/40 to-leaf-900/10"></div>
      <div class="relative flex h-full flex-col justify-end p-6 text-white">
        <p class="text-[0.65rem] uppercase tracking-[0.3em] text-leaf-200">
          {label}
        </p>
        <h3 class="mt-1 font-script text-3xl italic sm:text-4xl">
          {title}
        </h3>
      </div>
    </div>
  </label>
</div>