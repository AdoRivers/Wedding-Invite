---
import { event } from "../config/event.js";
import InfoCard from "./InfoCard.astro";

const cols = event.info.length > 1 ? "sm:grid-cols-2" : "sm:grid-cols-1 sm:max-w-sm sm:mx-auto";
---

<section
  class="px-6 py-16 sm:py-20"
  aria-labelledby="dresscode-title"
  data-info-section
>
  <div class="mx-auto max-w-md">
    <!-- Section header -->
    <div class="mb-8">
      <p class="mb-1 font-sans text-[9px] font-bold uppercase tracking-[0.45em] text-chrome-500">
        Vestimenta
      </p>
      <h2
        id="dresscode-title"
        class="font-sans text-2xl font-black uppercase tracking-tight text-chrome-900 sm:text-3xl"
      >
        Dress Code
      </h2>
      <div class="mt-3 h-[2px] w-10 bg-chrome-900" aria-hidden="true"></div>
    </div>

    <!-- Cards grid -->
    <div class={`grid grid-cols-1 gap-5 ${cols}`}>
      {event.info.map((card, i) => (
        <InfoCard
          id={`infocard-${card.key}`}
          label={card.label}
          title={card.title}
          description={card.description}
          image={card.image}
          icon={card.icon as "sparkles" | "hanger"}
          variant={i === 0 ? "soft" : "white"}
        />
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap, prefersReducedMotion, EASE } from "../lib/gsap.client.js";

  const section = document.querySelector<HTMLElement>("[data-info-section]");
  if (section) {
    const cards = section.querySelectorAll<HTMLElement>("[data-info-card]");

    if (prefersReducedMotion) {
      gsap.set(cards, { opacity: 1 });
    } else {
      gsap.fromTo(
        cards,
        { opacity: 0, y: 40, scale: 0.96 },
        {
          opacity: 1,
          y: 0,
          scale: 1,
          duration: 0.9,
          ease: EASE.expoOut,
          stagger: 0.15,
          scrollTrigger: {
            trigger: section,
            start: "top 85%",
            once: true,
          },
        }
      );
    }
  }
</script>
