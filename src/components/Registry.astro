---
import { event } from "../config/event.js";

const { title, description, url } = event.registry;
---

<section id="registry" class="px-6 py-16 sm:py-20" aria-labelledby="registry-section-title" data-registry>
  <div class="mx-auto max-w-md">

    <!-- Section header -->
    <div class="mb-8">
      <p class="mb-1 font-sans text-[9px] font-bold uppercase tracking-[0.45em] text-chrome-500">
        Regalos
      </p>
      <h2
        id="registry-section-title"
        class="font-sans text-2xl font-black uppercase tracking-tight text-chrome-900 sm:text-3xl"
      >
        Mesa de Regalos
      </h2>
      <div class="mt-3 h-[2px] w-10 bg-chrome-900" aria-hidden="true"></div>
    </div>

    <!-- Gift card -->
    <a
      href={url}
      data-anim
      class="group block rounded-card-lg border border-chrome-200 bg-chrome-50 p-8 text-center shadow-soft transition hover:-translate-y-0.5 hover:shadow-card"
      aria-labelledby="registry-title"
    >
      <div class="mx-auto mb-5 grid size-14 place-items-center rounded-full bg-chrome-900 text-chrome-50" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="20 12 20 22 4 22 4 12"></polyline>
          <rect x="2" y="7" width="20" height="5"></rect>
          <line x1="12" y1="22" x2="12" y2="7"></line>
          <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7Z"></path>
          <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7Z"></path>
        </svg>
      </div>

      <h3 id="registry-title" class="font-script text-2xl italic text-chrome-800">
        {title}
      </h3>
      <p class="mx-auto mt-2 max-w-[26ch] text-sm text-muted text-balance">
        {description}
      </p>

      <span class="mt-6 inline-flex items-center gap-2 rounded-full bg-chrome-900 px-6 py-2.5 text-[0.72rem] font-semibold uppercase tracking-wider text-chrome-50 transition group-hover:bg-chrome-800">
        Ver lista
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="transition-transform duration-300 group-hover:translate-x-0.5">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="13 6 19 12 13 18"></polyline>
        </svg>
      </span>
    </a>
  </div>
</section>

<script>
  import { gsap, prefersReducedMotion, EASE } from "../lib/gsap.client.js";

  const section = document.querySelector<HTMLElement>("[data-registry]");
  if (section) {
    const card = section.querySelector<HTMLElement>("[data-anim]");
    if (prefersReducedMotion) {
      gsap.set(card, { opacity: 1 });
    } else {
      gsap.fromTo(
        card,
        { opacity: 0, y: 32, scale: 0.97 },
        {
          opacity: 1,
          y: 0,
          scale: 1,
          duration: 0.9,
          ease: EASE.expoOut,
          scrollTrigger: { trigger: section, start: "top 85%", once: true },
        }
      );
    }
  }
</script>
