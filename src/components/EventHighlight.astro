---
import { event } from "../config/event.js";

const { eyebrow, title, description } = event.highlight;
---

<section class="px-6 py-8" aria-labelledby="highlight-title">
  <div class="mx-auto max-w-md">
    <article class="relative overflow-hidden rounded-card bg-leaf-700 px-6 py-8 text-center text-white shadow-card sm:px-8">
      <!-- Icono musical decorativo -->
      <span class="absolute right-5 top-5 text-leaf-300/70" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 18V5l12-2v13"></path>
          <circle cx="6" cy="18" r="3"></circle>
          <circle cx="18" cy="16" r="3"></circle>
        </svg>
      </span>

      <p class="text-[0.65rem] uppercase tracking-[0.3em] text-leaf-200">
        {eyebrow}
      </p>
      <h2
        id="highlight-title"
        class="mt-2 font-script text-3xl italic font-medium sm:text-4xl"
      >
        {title}
      </h2>
      <p class="mx-auto mt-3 max-w-xs text-sm text-leaf-100/90 text-balance">
        {description}
      </p>
    </article>
  </div>
</section>