---
import { event } from "../config/event.js";

const slides = event.gallery;
---

<section class="px-6 py-12 sm:py-16" aria-labelledby="gallery-title">
  <div class="mx-auto max-w-2xl">
    <h2
      id="gallery-title"
      class="text-center text-xs font-medium uppercase tracking-[0.3em] text-leaf-700 sm:text-sm"
    >
      Gallery
    </h2>

    <div
      class="relative mt-8"
      data-carousel
      role="region"
      aria-roledescription="carousel"
      aria-label="Galería de fotos"
    >
      <!-- Viewport: contiene el track y recorta lo que sale del marco -->
      <div
        class="overflow-hidden rounded-card shadow-soft aspect-[4/5] sm:aspect-[16/10] bg-leaf-100"
        data-viewport
      >
        <!-- Track: una fila de slides que se desplaza horizontalmente -->
        <div
          class="flex h-full w-full will-change-transform"
          data-track
          data-anim
        >
          {slides.map((photo, i) => (
            <div
              class="relative h-full w-full shrink-0 grow-0 basis-full overflow-hidden"
              data-slide
              role="group"
              aria-roledescription="slide"
              aria-label={`${i + 1} de ${slides.length}`}
            >
              <img
                src={photo.src}
                alt={photo.alt}
                loading={i === 0 ? "eager" : "lazy"}
                decoding="async"
                class="block h-full w-full object-cover"
                data-slide-image
              />
            </div>
          ))}
        </div>
      </div>

      <!-- Flechas -->
      <button
        type="button"
        data-prev
        aria-label="Foto anterior"
        class="absolute left-2 top-1/2 grid size-10 -translate-y-1/2 place-items-center rounded-full bg-white/90 text-leaf-800 shadow-soft transition hover:bg-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-leaf-700 sm:left-3 sm:size-11"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button
        type="button"
        data-next
        aria-label="Foto siguiente"
        class="absolute right-2 top-1/2 grid size-10 -translate-y-1/2 place-items-center rounded-full bg-white/90 text-leaf-800 shadow-soft transition hover:bg-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-leaf-700 sm:right-3 sm:size-11"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>

      <!-- Dots -->
      <div class="mt-5 flex items-center justify-center gap-2" data-dots>
        {slides.map((_, i) => (
          <button
            type="button"
            data-dot
            data-index={i}
            aria-label={`Ir a la foto ${i + 1}`}
            class="size-2 rounded-full bg-leaf-300 transition data-[active=true]:w-6 data-[active=true]:bg-leaf-700"
          ></button>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const root = document.querySelector<HTMLElement>("[data-carousel]");
  if (root) {
    const track = root.querySelector<HTMLElement>("[data-track]")!;
    const slides = root.querySelectorAll<HTMLElement>("[data-slide]");
    const images = root.querySelectorAll<HTMLImageElement>("[data-slide-image]");
    const prevBtn = root.querySelector<HTMLButtonElement>("[data-prev]")!;
    const nextBtn = root.querySelector<HTMLButtonElement>("[data-next]")!;
    const dots = root.querySelectorAll<HTMLButtonElement>("[data-dot]");

    const total = slides.length;
    let index = 0;
    let isAnimating = false;

    // ---------- Entrada del bloque ----------
    if (prefersReduced) {
      gsap.set(track, { opacity: 1 });
    } else {
      gsap.fromTo(
        track,
        { opacity: 0, y: 32 },
        {
          opacity: 1,
          y: 0,
          duration: 0.9,
          ease: "power3.out",
          scrollTrigger: { trigger: root, start: "top 85%", once: true },
        }
      );

      // Sutil "Ken Burns" en la imagen activa: zoom-in lento mientras está en pantalla
      const kenBurns = (img: HTMLImageElement) => {
        gsap.killTweensOf(img);
        gsap.fromTo(
          img,
          { scale: 1.0 },
          { scale: 1.06, duration: 6, ease: "none" }
        );
      };
      kenBurns(images[0]);
      // Re-aplicar al cambiar de slide (ver goTo)
      (root as any).__kenBurns = kenBurns;
    }

    // ---------- Lógica de navegación ----------
    const updateDots = () => {
      dots.forEach((d, i) => d.setAttribute("data-active", String(i === index)));
    };

    const goTo = (next: number, direction: 1 | -1) => {
      if (isAnimating || next === index) return;
      isAnimating = true;

      // Normalizar índice (loop)
      const normalized = (next + total) % total;

      if (prefersReduced) {
        gsap.set(track, { xPercent: -normalized * 100 });
        index = normalized;
        updateDots();
        isAnimating = false;
        return;
      }

      gsap.to(track, {
        xPercent: -normalized * 100,
        duration: 0.85,
        ease: "power3.inOut",
        onComplete: () => {
          index = normalized;
          updateDots();
          isAnimating = false;
          const kb = (root as any).__kenBurns;
          if (kb) kb(images[index]);
        },
      });
    };

    const next = () => goTo(index + 1, 1);
    const prev = () => goTo(index - 1, -1);

    nextBtn.addEventListener("click", next);
    prevBtn.addEventListener("click", prev);
    dots.forEach((dot, i) =>
      dot.addEventListener("click", () => goTo(i, i > index ? 1 : -1))
    );

    // Teclado (cuando el carrusel tiene foco)
    root.addEventListener("keydown", (e) => {
      if (e.key === "ArrowRight") { e.preventDefault(); next(); }
      if (e.key === "ArrowLeft")  { e.preventDefault(); prev(); }
    });
    root.tabIndex = 0;

    // ---------- Swipe táctil con Pointer Events ----------
    let startX = 0;
    let dragging = false;

    track.addEventListener("pointerdown", (e) => {
      if (isAnimating) return;
      dragging = true;
      startX = e.clientX;
      track.setPointerCapture(e.pointerId);
    });
    track.addEventListener("pointerup", (e) => {
      if (!dragging) return;
      dragging = false;
      const dx = e.clientX - startX;
      const threshold = 40;
      if (dx <= -threshold) next();
      else if (dx >= threshold) prev();
    });
    track.addEventListener("pointercancel", () => { dragging = false; });

    // Inicial
    updateDots();
  }
</script>