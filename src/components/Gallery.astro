---
import { event } from "../config/event.js";

const slides = event.gallery;
---

<section class="px-6 py-12 sm:py-16" aria-labelledby="gallery-title">
  <div class="mx-auto max-w-2xl">
    <h2
      id="gallery-title"
      class="text-center text-xs font-medium uppercase tracking-[0.3em] text-leaf-700 sm:text-sm"
    >
      Gallery
    </h2>

    <div
      class="relative mt-8"
      data-carousel
      role="region"
      aria-roledescription="carousel"
      aria-label="Galería de fotos"
    >
      <!-- Viewport con aspect ratio fijo y marco verde -->
      <div
        class="overflow-hidden rounded-card-lg shadow-glow ring-1 ring-leaf-200/60 aspect-[4/5] sm:aspect-[16/10] bg-leaf-100"
        data-viewport
      >
        <div
          class="flex h-full w-full will-change-transform"
          data-track
          data-anim
        >
          {slides.map((photo, i) => (
            <div
              class="relative h-full w-full shrink-0 grow-0 basis-full overflow-hidden"
              data-slide
              role="group"
              aria-roledescription="slide"
              aria-label={`${i + 1} de ${slides.length}`}
            >
              <img
                src={photo.src}
                alt={photo.alt}
                loading={i === 0 ? "eager" : "lazy"}
                decoding="async"
                class="block h-full w-full object-cover"
                data-slide-image
              />
            </div>
          ))}
        </div>

        <!-- Contador "1 / 3" -->
        <div class="absolute bottom-4 left-4 rounded-full bg-leaf-900/55 px-3 py-1 text-[0.65rem] font-medium tracking-widest text-white backdrop-blur">
          <span data-counter-current>1</span>
          <span class="opacity-60">/ {slides.length}</span>
        </div>
      </div>

      <!-- Flechas -->
      <button
        type="button"
        data-prev
        aria-label="Foto anterior"
        class="absolute left-2 top-1/2 grid size-11 -translate-y-1/2 place-items-center rounded-full bg-white/95 text-leaf-800 shadow-card transition hover:scale-105 hover:bg-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-leaf-700 sm:left-3"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button
        type="button"
        data-next
        aria-label="Foto siguiente"
        class="absolute right-2 top-1/2 grid size-11 -translate-y-1/2 place-items-center rounded-full bg-white/95 text-leaf-800 shadow-card transition hover:scale-105 hover:bg-white focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-leaf-700 sm:right-3"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>

      <!-- Dots -->
      <div class="mt-6 flex items-center justify-center gap-2" data-dots>
        {slides.map((_, i) => (
          <button
            type="button"
            data-dot
            data-index={i}
            aria-label={`Ir a la foto ${i + 1}`}
            class="h-2 w-2 rounded-full bg-leaf-300 transition-all duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] data-[active=true]:w-7 data-[active=true]:bg-leaf-700"
          ></button>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap, prefersReducedMotion, EASE } from "../lib/gsap.client.js";

  const root = document.querySelector<HTMLElement>("[data-carousel]");
  if (root) {
    const track = root.querySelector<HTMLElement>("[data-track]")!;
    const slides = root.querySelectorAll<HTMLElement>("[data-slide]");
    const images = root.querySelectorAll<HTMLImageElement>("[data-slide-image]");
    const prevBtn = root.querySelector<HTMLButtonElement>("[data-prev]")!;
    const nextBtn = root.querySelector<HTMLButtonElement>("[data-next]")!;
    const dots = root.querySelectorAll<HTMLButtonElement>("[data-dot]");
    const counter = root.querySelector<HTMLElement>("[data-counter-current]");

    const total = slides.length;
    let index = 0;
    let isAnimating = false;

    // ---------- Entrada del bloque ----------
    if (prefersReducedMotion) {
      gsap.set(track, { opacity: 1 });
    } else {
      gsap.fromTo(
        track,
        { opacity: 0, y: 40 },
        {
          opacity: 1,
          y: 0,
          duration: 0.9,
          ease: EASE.expoOut,
          scrollTrigger: { trigger: root, start: "top 85%", once: true },
        }
      );
    }

    // ---------- Ken Burns sobre la imagen activa ----------
    const kenBurns = (img: HTMLImageElement) => {
      if (prefersReducedMotion) return;
      gsap.killTweensOf(img);
      gsap.fromTo(
        img,
        { scale: 1.0 },
        { scale: 1.08, duration: 7, ease: "none" }
      );
    };
    kenBurns(images[0]);

    // ---------- Navegación ----------
    const updateUI = () => {
      dots.forEach((d, i) => d.setAttribute("data-active", String(i === index)));
      if (counter) counter.textContent = String(index + 1);
    };

    const goTo = (next: number) => {
      if (isAnimating || next === index) return;
      isAnimating = true;
      const normalized = (next + total) % total;

      if (prefersReducedMotion) {
        gsap.set(track, { xPercent: -normalized * 100 });
        index = normalized;
        updateUI();
        isAnimating = false;
        return;
      }

      gsap.to(track, {
        xPercent: -normalized * 100,
        duration: 0.85,
        ease: EASE.inOut,
        onComplete: () => {
          index = normalized;
          updateUI();
          isAnimating = false;
          kenBurns(images[index]);
        },
      });
    };

    const next = () => goTo(index + 1);
    const prev = () => goTo(index - 1);

    nextBtn.addEventListener("click", next);
    prevBtn.addEventListener("click", prev);
    dots.forEach((dot, i) => dot.addEventListener("click", () => goTo(i)));

    // Teclado
    root.addEventListener("keydown", (e) => {
      if (e.key === "ArrowRight") { e.preventDefault(); next(); }
      if (e.key === "ArrowLeft")  { e.preventDefault(); prev(); }
    });
    root.tabIndex = 0;

    // Swipe táctil
    let startX = 0;
    let dragging = false;
    track.addEventListener("pointerdown", (e) => {
      if (isAnimating) return;
      dragging = true;
      startX = e.clientX;
      track.setPointerCapture(e.pointerId);
    });
    track.addEventListener("pointerup", (e) => {
      if (!dragging) return;
      dragging = false;
      const dx = e.clientX - startX;
      if (dx <= -40) next();
      else if (dx >= 40) prev();
    });
    track.addEventListener("pointercancel", () => { dragging = false; });

    updateUI();
  }
</script>