---
import { event } from "../config/event.js";
---

<section
  id="countdown"
  class="px-6 py-16 sm:py-20"
  aria-labelledby="countdown-title"
>
  <div class="mx-auto max-w-md text-center">
    <h2
      id="countdown-title"
      class="text-xs font-medium uppercase tracking-[0.3em] text-leaf-700 sm:text-sm"
    >
      Countdown to party
    </h2>

    <div
      class="mt-8 grid grid-cols-4 gap-4 sm:gap-8 font-script"
      data-countdown
      data-target={event.date}
    >
      {[
        { key: "days", label: "Days" },
        { key: "hours", label: "Hours" },
        { key: "mins", label: "Mins" },
        { key: "segs", label: "Segs"}
      ].map(({ key, label }) => (
        <div class="flex flex-col items-center border-b border-leaf-300 pb-3">
          <span
            data-unit={key}
            class="text-3xl font-bold tabular-nums text-leaf-800 sm:text-4xl"
          >00</span>
          <span class="mt-2 text-[0.65rem] uppercase tracking-widest text-muted sm:text-xs">
            {label}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  // JS mínimo y autocontenido — solo cuenta regresiva.
  const root = document.querySelector<HTMLElement>("[data-countdown]");
  if (root?.dataset.target) {
    const target = new Date(root.dataset.target).getTime();
    const units = {
      days: root.querySelector<HTMLElement>('[data-unit="days"]'),
      hours: root.querySelector<HTMLElement>('[data-unit="hours"]'),
      mins: root.querySelector<HTMLElement>('[data-unit="mins"]'),
      segs: root.querySelector<HTMLElement>('[data-unit="segs"]')
    };

    const pad = (n: number) => String(Math.max(0, n)).padStart(2, "0");

    const tick = () => {
      const diff = target - Date.now();
      if (diff <= 0) {
        Object.values(units).forEach((el) => el && (el.textContent = "00"));
        return false;
      }
      const days = Math.floor(diff / 86_400_000);
      const hours = Math.floor((diff % 86_400_000) / 3_600_000);
      const mins = Math.floor((diff % 3_600_000) / 60_000);
      const segs = Math.floor((diff % 60_000) / 1_000);
      if (units.days) units.days.textContent = pad(days);
      if (units.hours) units.hours.textContent = pad(hours);
      if (units.mins) units.mins.textContent = pad(mins);
      if (units.segs) units.segs.textContent = pad(segs);
      return true;
    };

    if (tick()) setInterval(tick, 1_000);
  }
</script>