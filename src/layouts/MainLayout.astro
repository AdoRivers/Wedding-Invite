---
import "../styles/global.css";
import { event } from "../config/event.js";

interface Props {
  title?: string;
}

const { title = event.hero.title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={`${event.hero.title} — ${event.hero.eyebrow}`} />
    <link rel="icon" type="image/svg+xml" href="/birthday-cake.svg" />
    <link rel="icon" href="/birthday-cake.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen overflow-x-hidden bg-canvas text-ink">
    <slot />
  </body>
</html>