---
import "../styles/global.css";
import { event } from "../components/event.js";

interface Props {
  title?: string;
}

const { title = event.title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={`${event.title} — ${event.subtitle}`} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-accent">
    <header
      class="sticky top-0 z-20 flex items-center justify-between bg-surface/90 px-4 py-3 backdrop-blur sm:px-8"
    >
      <span class="text-sm font-semibold text-primary sm:text-base">
        {event.title}
      </span>
      <button
        type="button"
        aria-label="Compartir invitación"
        class="rounded-full p-2 text-primary transition hover:bg-accent"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="18" cy="5" r="3"></circle>
          <circle cx="6" cy="12" r="3"></circle>
          <circle cx="18" cy="19" r="3"></circle>
          <line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line>
          <line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
        </svg>
      </button>
    </header>

    <main class="mx-auto w-full max-w-2xl px-4 pb-16 pt-6 sm:px-6">
      <slot />
    </main>
  </body>
</html>